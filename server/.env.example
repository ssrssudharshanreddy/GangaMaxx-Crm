# Backend Server Configuration
PORT=5001

# Firebase Admin SDK Configuration
# Get service account from Firebase Console: Project Settings > Service Accounts > Generate New Private Key
# Then stringify the JSON file contents and paste here
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"ganga-maxx-crm",...}

# Or set the project ID if using Application Default Credentials
VITE_FIREBASE_PROJECT_ID=ganga-maxx-crm

# CORS Configuration
# Adjust for production to match your frontend domain
NODE_ENV=development
