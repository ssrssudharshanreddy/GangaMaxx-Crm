rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // HELPER FUNCTIONS
    // ==========================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isActive() {
      return isAuthenticated() && getUserData().status == 'active';
    }

    function getRole() {
      return getUserData().role;
    }

    /**
     * Canonical role check — supports both the new PascalCase role names
     * (set by AuthContext normalization) and legacy lowercase variants
     * for backward-compatibility during migration.
     */
    function isSuperAdmin() {
      return isActive() && (
        getRole() == 'Super Admin' ||
        getRole() == 'owner'
      );
    }

    function isSalesExecutive() {
      return isActive() && (
        getRole() == 'Sales Executive' ||
        getRole() == 'sales_admin' ||
        getRole() == 'salesAdmin'
      );
    }

    function isSalesman() {
      return isActive() && (
        getRole() == 'Salesman' ||
        getRole() == 'salesman'
      );
    }

    function isAccountsExecutive() {
      return isActive() && (
        getRole() == 'Accounts Executive' ||
        getRole() == 'accounts_executive' ||
        getRole() == 'accounts_manager' ||
        getRole() == 'accountsManager'
      );
    }

    function isWarehouseExecutive() {
      return isActive() && (
        getRole() == 'Warehouse Executive' ||
        getRole() == 'warehouse_manager' ||
        getRole() == 'warehouseExecutive'
      );
    }

    function isWarehouseStaff() {
      return isActive() && (
        getRole() == 'Warehouse Staff' ||
        getRole() == 'warehouse_staff' ||
        getRole() == 'warehouseStaff'
      );
    }

    function isWarehouseTeam() {
      return isWarehouseExecutive() || isWarehouseStaff();
    }

    function isSalesTeam() {
      return isSalesExecutive() || isSalesman();
    }

    function isCRMStaff() {
      return isSuperAdmin() || isSalesExecutive() || isSalesman() ||
             isAccountsExecutive() || isWarehouseExecutive() || isWarehouseStaff();
    }

    function isCustomer() {
      return isActive() && (
        getRole() == 'Customer' ||
        getRole() == 'customer' ||
        getRole() == 'customer_admin' ||
        getRole() == 'customer_user'
      );
    }

    function belongsToInstitution(instId) {
      return isActive() && getUserData().institutionId == instId;
    }

    // ==========================================
    // GOVERNANCE MANDATE: NO HARD DELETES
    // All collections enforce "Archive Only".
    // Hard deletes are NEVER permitted via client.
    // ==========================================

    // ==========================================
    // COLLECTION RULES
    // ==========================================

    // 1. USERS COLLECTION
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        isSalesExecutive()
      );
      allow create: if isSuperAdmin() || isSalesExecutive() ||
                    (isAuthenticated() && request.auth.uid == userId);
      allow update: if isSuperAdmin() || isSalesExecutive() || (
        request.auth.uid == userId &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'disabled', 'status'])
      );
      // GOVERNANCE: No hard deletes
      allow delete: if false;
    }

    // 2. INSTITUTIONS COLLECTION
    match /institutions/{instId} {
      allow read: if isCRMStaff() || belongsToInstitution(instId);
      allow create: if isSuperAdmin() || isSalesExecutive();
      allow update: if isSuperAdmin() || isSalesExecutive() || isAccountsExecutive();
      // GOVERNANCE: No hard deletes — use status: 'archived'
      allow delete: if false;
    }

    // 3. STAFF COLLECTION
    match /staff/{memberId} {
      allow read: if isCRMStaff();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      // GOVERNANCE: No hard deletes
      allow delete: if false;
    }

    // 4. ORDERS COLLECTION
    match /orders/{orderId} {
      allow read: if isSuperAdmin() ||
                  isSalesExecutive() ||
                  isWarehouseTeam() ||
                  isAccountsExecutive() ||
                  (isSalesman() && resource.data.salesmanId == request.auth.uid) ||
                  (isCustomer() && (resource.data.linkedUid == request.auth.uid || belongsToInstitution(resource.data.institutionId)));

      allow create: if isSuperAdmin() || isSalesExecutive() || isSalesman() ||
                    (isCustomer() && request.resource.data.institutionId == getUserData().institutionId);

      allow update: if isSuperAdmin() ||
                    isSalesExecutive() ||
                    (isAccountsExecutive() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paymentStatus', 'paymentDate', 'paymentRef', 'status'])) ||
                    (isWarehouseTeam() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dispatchStatus', 'dispatchDate', 'trackingNumber', 'status'])) ||
                    (isCustomer() && belongsToInstitution(resource.data.institutionId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notes']));

      // GOVERNANCE: No hard deletes
      allow delete: if false;
    }

    // 5. QUOTATIONS COLLECTION
    match /quotations/{quotationId} {
      allow read: if isSuperAdmin() || isSalesTeam() ||
                  (isCustomer() && belongsToInstitution(resource.data.institutionId));
      allow create: if isSuperAdmin() || isSalesTeam();
      allow update: if isSuperAdmin() || isSalesExecutive();
      // GOVERNANCE: No hard deletes
      allow delete: if false;
    }

    // 6. INVOICES COLLECTION
    match /invoices/{invoiceId} {
      allow read: if isSuperAdmin() || isSalesExecutive() || isAccountsExecutive() ||
                  (isCustomer() && belongsToInstitution(resource.data.institutionId));
      allow create: if isSuperAdmin() || isAccountsExecutive();
      allow update: if isSuperAdmin() || isAccountsExecutive();
      // GOVERNANCE: No hard deletes
      allow delete: if false;
    }

    // 7. PAYMENTS COLLECTION
    match /payments/{paymentId} {
      allow read: if isSuperAdmin() || isSalesExecutive() || isAccountsExecutive() ||
                  (isCustomer() && belongsToInstitution(resource.data.institutionId));
      allow create: if isSuperAdmin() || isAccountsExecutive() ||
                    (isCustomer() && request.resource.data.institutionId == getUserData().institutionId);
      allow update: if isSuperAdmin() || isAccountsExecutive();
      // GOVERNANCE: No hard deletes
      allow delete: if false;
    }

    // 8. CREDIT ACCOUNTS COLLECTION
    match /creditAccounts/{accId} {
      allow read: if isSuperAdmin() || isAccountsExecutive() ||
                  (isCustomer() && belongsToInstitution(resource.data.institutionId));
      allow create: if isSuperAdmin() || isAccountsExecutive();
      allow update: if isSuperAdmin() || isAccountsExecutive();
      // GOVERNANCE: No hard deletes
      allow delete: if false;
    }

    // 9. PRODUCTS COLLECTION
    match /products/{productId} {
      allow read: if isCRMStaff();
      allow create: if isSuperAdmin() || isWarehouseExecutive();
      allow update: if isSuperAdmin() || isWarehouseExecutive();
      // GOVERNANCE: No hard deletes
      allow delete: if false;
    }

    // 10. INVENTORY COLLECTION
    match /inventory/{itemId} {
      allow read: if isSuperAdmin() || isWarehouseTeam();
      allow create: if isSuperAdmin() || isWarehouseExecutive();
      allow update: if isSuperAdmin() || isWarehouseExecutive();
      // GOVERNANCE: No hard deletes
      allow delete: if false;
    }

    // 11. PROCUREMENT COLLECTION
    match /procurement/{poId} {
      allow read: if isSuperAdmin() || isWarehouseTeam();
      allow create: if isSuperAdmin() || isWarehouseExecutive();
      allow update: if isSuperAdmin() || isWarehouseExecutive() || isWarehouseStaff();
      // GOVERNANCE: No hard deletes
      allow delete: if false;
    }

    // 12. RETURNS COLLECTION
    match /returns/{returnId} {
      allow read: if isCRMStaff() ||
                  (isCustomer() && belongsToInstitution(resource.data.institutionId));
      allow create: if isSuperAdmin() || isSalesTeam() ||
                    (isCustomer() && request.resource.data.institutionId == getUserData().institutionId);
      allow update: if isSuperAdmin() || isSalesExecutive() || isAccountsExecutive() || isWarehouseTeam();
      // GOVERNANCE: No hard deletes
      allow delete: if false;
    }

    // 13. DELIVERIES COLLECTION
    match /deliveries/{deliveryId} {
      allow read: if isSuperAdmin() || isWarehouseTeam() || isSalesExecutive();
      allow create: if isSuperAdmin() || isWarehouseExecutive();
      allow update: if isSuperAdmin() || isWarehouseTeam();
      // GOVERNANCE: No hard deletes
      allow delete: if false;
    }

    // 14. VISIT LOGS COLLECTION
    match /visitLogs/{logId} {
      allow read: if isSuperAdmin() || isSalesExecutive() ||
                  (isSalesman() && resource.data.salesmanId == request.auth.uid);
      allow create: if isSuperAdmin() || isSalesTeam();
      allow update: if isSuperAdmin() || isSalesExecutive();
      // GOVERNANCE: No hard deletes
      allow delete: if false;
    }

    // 15. FOLLOW-UPS COLLECTION
    match /followUps/{followId} {
      allow read: if isSuperAdmin() || isSalesExecutive() ||
                  (isSalesman() && resource.data.assignedTo == request.auth.uid);
      allow create: if isSuperAdmin() || isSalesTeam();
      allow update: if isSuperAdmin() || isSalesExecutive() ||
                    (isSalesman() && resource.data.assignedTo == request.auth.uid);
      // GOVERNANCE: No hard deletes
      allow delete: if false;
    }

    // 16. SUPPORT TICKETS COLLECTION
    match /tickets/{ticketId} {
      allow read: if isSuperAdmin() || isSalesExecutive() || isSalesman() || isAccountsExecutive() ||
                  (isCustomer() && belongsToInstitution(resource.data.institutionId));
      allow create: if isCRMStaff() ||
                    (isCustomer() && request.resource.data.institutionId == getUserData().institutionId);
      allow update: if isSuperAdmin() || isSalesExecutive() ||
                    (isCustomer() && belongsToInstitution(resource.data.institutionId));
      // GOVERNANCE: No hard deletes
      allow delete: if false;
    }

    // 17. NOTIFICATIONS COLLECTION
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && (
        resource.data.recipientId == request.auth.uid || isCRMStaff()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.recipientId == request.auth.uid || isSuperAdmin()
      );
      // GOVERNANCE: No hard deletes
      allow delete: if false;
    }

    // 18. AUDIT LOGS — IMMUTABLE
    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false; // Immutable audit trail
    }
    match /audits/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false; // Immutable audit trail
    }

    // 19. COUNTERS — Internal use
    match /counters/{counterId} {
      allow read, write: if isCRMStaff();
    }

    // 20. DEFAULT SECURITY GUARD — deny all unlisted paths
    match /{document=**} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }
  }
}
