rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isActive() {
      return isAuthenticated() && getUserData().status == 'active';
    }
    
    function getRole() {
      return getUserData().role;
    }

    function hasRole(role) {
      return isActive() && (
        getRole() == role ||
        (role == 'owner' && getRole() == 'owner') ||
        (role == 'salesAdmin' && (getRole() == 'salesAdmin' || getRole() == 'sales_admin')) ||
        (role == 'salesman' && getRole() == 'salesman') ||
        (role == 'accountsManager' && (getRole() == 'accountsManager' || getRole() == 'accounts_manager')) ||
        (role == 'complianceAdmin' && (getRole() == 'complianceAdmin' || getRole() == 'compliance_admin')) ||
        (role == 'supportStaff' && (getRole() == 'supportStaff' || getRole() == 'support_staff')) ||
        (role == 'warehouseStaff' && (getRole() == 'warehouseStaff' || getRole() == 'warehouse_staff')) ||
        (role == 'customer' && (getRole() == 'customer' || getRole() == 'customer_owner' || getRole() == 'customer_buyer'))
      );
    }

    function isCRMStaff() {
      return isActive() && (
        getRole() in ['owner', 'salesAdmin', 'sales_admin', 'salesman', 'accountsManager', 'accounts_manager', 'complianceAdmin', 'compliance_admin', 'supportStaff', 'support_staff', 'warehouseStaff', 'warehouse_staff']
      );
    }

    function isCustomer() {
      return hasRole('customer');
    }
    
    function belongsToInstitution(instId) {
      return isActive() && getUserData().institutionId == instId;
    }

    // USERS collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || hasRole('owner') || hasRole('salesAdmin'));
      allow create: if hasRole('owner') || hasRole('salesAdmin');
      allow update: if hasRole('owner') ||
                    (request.auth.uid == userId &&
                     !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'disabled', 'status']));
      allow delete: if hasRole('owner');
    }

    // STAFF collection
    match /staff/{staffId} {
      allow read: if isAuthenticated();
      allow create, update: if hasRole('owner');
      allow delete: if false;
    }

    // ROLES collection
    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('owner');
    }

    // CUSTOMERS / INSTITUTIONS
    match /customers/{customerId} {
      allow read: if isCRMStaff() || (isCustomer() && resource.data.linkedUid == request.auth.uid);
      allow create: if hasRole('owner') || hasRole('salesAdmin') || hasRole('salesman');
      allow update: if hasRole('owner') || hasRole('salesAdmin') || hasRole('salesman') || hasRole('supportStaff');
      allow delete: if hasRole('owner');
    }

    match /institutions/{instId} {
      allow read: if isCRMStaff() || belongsToInstitution(instId);
      allow create, update: if hasRole('owner') || hasRole('salesAdmin') || hasRole('complianceAdmin');
      allow delete: if false;
    }

    // CRM Follow Ups
    match /followUps/{followId} {
      allow read: if isCRMStaff();
      allow write: if hasRole('owner') || hasRole('salesAdmin') || hasRole('salesman');
    }
    match /follow_ups/{followId} {
      allow read: if isCRMStaff();
      allow write: if hasRole('owner') || hasRole('salesAdmin') || hasRole('salesman');
    }

    // Visit Logs
    match /visitLogs/{logId} {
      allow read: if isCRMStaff();
      allow write: if hasRole('owner') || hasRole('salesAdmin') || hasRole('salesman');
    }
    match /visit_logs/{logId} {
      allow read: if isCRMStaff();
      allow write: if hasRole('owner') || hasRole('salesAdmin') || hasRole('salesman');
    }

    // ORDERS
    match /orders/{orderId} {
      allow read: if isCRMStaff() || (isCustomer() && (resource.data.linkedUid == request.auth.uid || belongsToInstitution(resource.data.institutionId)));
      allow create: if isCRMStaff() || isCustomer();
      allow update: if hasRole('owner') || hasRole('salesAdmin') ||
                    (hasRole('warehouseStaff') && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dispatchStatus', 'dispatchDate', 'trackingNumber', 'status'])) ||
                    (hasRole('accountsManager') && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paymentStatus', 'paymentDate', 'paymentRef', 'status']));
      allow delete: if hasRole('owner');
    }

    match /order_items/{itemId} {
      allow read: if isCRMStaff() || (isCustomer() && belongsToInstitution(resource.data.institutionId));
      allow create, update: if isCRMStaff();
      allow delete: if false;
    }

    // INVOICES
    match /invoices/{invoiceId} {
      allow read: if hasRole('owner') || hasRole('salesAdmin') || hasRole('accountsManager') || (isCustomer() && (resource.data.linkedUid == request.auth.uid || belongsToInstitution(resource.data.institutionId)));
      allow create, update: if hasRole('owner') || hasRole('salesAdmin') || hasRole('accountsManager');
      allow delete: if hasRole('owner');
    }

    // PAYMENTS
    match /payments/{paymentId} {
      allow read: if hasRole('owner') || hasRole('salesAdmin') || hasRole('accountsManager') || (isCustomer() && (resource.data.linkedUid == request.auth.uid || belongsToInstitution(resource.data.institutionId)));
      allow create: if hasRole('owner') || hasRole('accountsManager') || isCustomer();
      allow update, delete: if hasRole('owner');
    }

    // PRODUCTS
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('owner') || hasRole('salesAdmin') || hasRole('warehouseStaff');
    }

    match /categories/{catId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('owner') || hasRole('salesAdmin') || hasRole('warehouseStaff');
    }

    match /stock_batches/{batchId} {
      allow read, write: if hasRole('owner') || hasRole('warehouseStaff');
    }

    // DOCUMENTS (KYC, agreements)
    match /documents/{docId} {
      allow read: if hasRole('owner') || hasRole('complianceAdmin') || hasRole('salesAdmin') || (isCustomer() && resource.data.ownerId == request.auth.uid);
      allow create: if hasRole('owner') || hasRole('complianceAdmin') || hasRole('salesAdmin') || isCustomer();
      allow update, delete: if hasRole('owner') || hasRole('complianceAdmin');
    }

    // SUPPORT TICKETS
    match /tickets/{ticketId} {
      allow read: if hasRole('owner') || hasRole('supportStaff') || hasRole('salesAdmin') || (isCustomer() && (resource.data.createdBy == request.auth.uid || belongsToInstitution(resource.data.institutionId)));
      allow create: if isAuthenticated();
      allow update: if hasRole('owner') || hasRole('supportStaff') ||
                    (isCustomer() && (resource.data.createdBy == request.auth.uid || belongsToInstitution(resource.data.institutionId)) &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastCustomerMessage', 'updatedAt', 'messages']));
      allow delete: if hasRole('owner');
    }
    match /support_tickets/{ticketId} {
      allow read: if hasRole('owner') || hasRole('supportStaff') || hasRole('salesAdmin') || (isCustomer() && (resource.data.createdBy == request.auth.uid || belongsToInstitution(resource.data.institutionId)));
      allow create: if isAuthenticated();
      allow update: if hasRole('owner') || hasRole('supportStaff') ||
                    (isCustomer() && (resource.data.createdBy == request.auth.uid || belongsToInstitution(resource.data.institutionId)) &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastCustomerMessage', 'updatedAt', 'messages']));
      allow delete: if hasRole('owner');
    }

    // AUDIT LOGS (immutable & append-only)
    match /auditLogs/{logId} {
      allow read: if hasRole('owner') || hasRole('complianceAdmin');
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
    match /audits/{logId} {
      allow read: if hasRole('owner') || hasRole('complianceAdmin');
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // NOTIFICATIONS
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && (resource.data.recipientId == request.auth.uid || resource.data.targetUid == request.auth.uid);
      allow create: if isCRMStaff();
      allow update: if isAuthenticated() && (resource.data.recipientId == request.auth.uid || resource.data.targetUid == request.auth.uid) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt', 'dismissed', 'read']);
      allow delete: if hasRole('owner');
    }

    // TASKS / FOLLOW-UPS
    match /tasks/{taskId} {
      allow read: if hasRole('owner') || hasRole('salesAdmin') || (hasRole('salesman') && resource.data.assignedTo == request.auth.uid);
      allow create, update: if hasRole('owner') || hasRole('salesAdmin') || hasRole('salesman');
      allow delete: if hasRole('owner') || hasRole('salesAdmin');
    }

    // SETTINGS
    match /settings/{settingId} {
      allow read: if isCRMStaff();
      allow write: if hasRole('owner');
    }

    // RETURNS
    match /returns/{retId} {
      allow read: if isCRMStaff() || belongsToInstitution(resource.data.institutionId);
      allow create: if isCRMStaff() || isCustomer();
      allow update: if hasRole('owner') || hasRole('warehouseStaff');
      allow delete: if false;
    }

    // PROCUREMENT & SUPPLIERS
    match /procurement/{poId} {
      allow read, write: if hasRole('owner') || hasRole('warehouseStaff');
    }
    match /suppliers/{supId} {
      allow read, write: if hasRole('owner') || hasRole('warehouseStaff');
    }

    // COMPLIANCE RECORDS
    match /compliance_records/{recordId} {
      allow read: if isCRMStaff() || belongsToInstitution(resource.data.institutionId);
      allow write: if hasRole('owner') || hasRole('complianceAdmin');
    }

    // COUNTERS
    match /counters/{counterId} {
      allow read, write: if isAuthenticated();
    }

    // Default deny rule
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
